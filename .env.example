# Convex Configuration
# Get this from https://dashboard.convex.dev after creating your project
EXPO_PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# Clerk Authentication
# Get this from https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxx

# Clerk JWT Issuer Domain (for Convex auth)
# Format: https://your-clerk-domain.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Google Maps SDK for Android (iOS uses Apple Maps and does NOT need a key)
# Create at https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_ANDROID_KEY=AIza_your_key_here
